{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": ["python@latest"],
  "shell": {
    "init_hook": [
      "export DEVBOX_PYTHON_VENV=\"$DEVBOX_PROJECT_ROOT/.devbox/venv\"",
      "if [ ! -x \"$DEVBOX_PYTHON_VENV/bin/python\" ]; then python -m venv \"$DEVBOX_PYTHON_VENV\"; fi",
      "if [ ! -x \"$DEVBOX_PYTHON_VENV/bin/pip\" ]; then \"$DEVBOX_PYTHON_VENV/bin/python\" -m ensurepip --upgrade >/dev/null 2>&1 || true; fi",
      "export VIRTUAL_ENV=\"$DEVBOX_PYTHON_VENV\"",
      "export PATH=\"$DEVBOX_PYTHON_VENV/bin:$PATH\""
    ],
    "scripts": {
      "dbus-autoterm:run:dummy": [
        "PYTHONPATH=dbus-autoterm python3 -m app --backend=dummy --mock-dbus"
      ],
      "dbus-autoterm:check": [
        "PYTHONPATH=dbus-autoterm python3 -m compileall dbus-autoterm"
      ],
      "dbus-autoterm:test": [
        "PYTHONPATH=dbus-autoterm:emulation python3 -m unittest discover -s dbus-autoterm/tests -v"
      ],

      "emulation:run:pty": [
        "PYTHONPATH=emulation python3 -m emulator --transport pty"
      ],
      "emulation:run:gpio": [
        "PYTHONPATH=emulation python3 -m emulator --transport serial --device /dev/ttyAMA0"
      ],
      "emulation:check": [
        "PYTHONPATH=emulation python3 -m compileall emulation"
      ],
      "emulation:test": [
        "PYTHONPATH=emulation python3 -m unittest discover -s emulation/tests -v"
      ],

      "test": ["devbox run emulation:test", "devbox run dbus-autoterm:test"],
      "check": ["devbox run emulation:check", "devbox run dbus-autoterm:check"],
      "package": ["make package"]
    }
  }
}
