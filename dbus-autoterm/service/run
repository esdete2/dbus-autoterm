#!/bin/sh
set -eu

echo "*** starting dbus-autoterm ***"
exec 2>&1

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
APP_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
CONFIG_FILE="$APP_ROOT/config.ini"
APP_FILE="$APP_ROOT/app.py"
PYTHON_BIN="${PYTHON_BIN:-python3}"

cd "$APP_ROOT"
export PYTHONUNBUFFERED=1
export PYTHONDONTWRITEBYTECODE=1
export PYTHONPATH="$APP_ROOT${PYTHONPATH:+:$PYTHONPATH}"

if ! command -v "$PYTHON_BIN" >/dev/null 2>&1; then
    echo "Missing Python runtime: $PYTHON_BIN"
    exit 1
fi

if [ ! -f "$APP_FILE" ]; then
    echo "Missing application file: $APP_FILE"
    exit 1
fi

if [ ! -f "$CONFIG_FILE" ]; then
    echo "Missing configuration file: $CONFIG_FILE"
    exit 1
fi

exec "$PYTHON_BIN" "$APP_FILE" -c "$CONFIG_FILE"
